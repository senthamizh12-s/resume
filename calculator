<DOCTYPE.html>
<html>
<head>
<title>Calculator</title>
<style>
.calculator{
backgroud-color:blue;
padding : 30px;
border-radius:15px;
}
button{
color:white;
background-color:black;
height:45px;
width:45px;
margin:5px;

}
.operator{
color:white;
background-color:blue;
}
.equal{
color:black;
background-color:green;
}
.char{
color:white;
background-color:blue;
}
#display{
width:230px;
}

</style>
</head>
<body>
<div class ="calculator">
<input type = "text" id = "display"><br>
<br>
<button onclick="add('+')">+</button>

<button onclick="add('%')">%</button>

<button class="special" onclick="clearDisplay()">C</button>

<button class = "char" onclick="deleteChar()">x</button>

<br>



<button onclick="add('7')">7</button>

<button onclick="add('8')">8</button>

<button onclick="add('9')">9</button>

<button class="operator" onclick="add('/')">÷</button>



<br>



<button onclick="add('4')">4</button>

<button onclick="add('5')">5</button>

<button onclick="add('6')">6</button>

<button class="operator" onclick="add('*')">×</button>



<br>

<button onclick="add('1')">1</button>

<button onclick="add('2')">2</button>

<button onclick="add('3')">3</button>

<button class="operator" onclick="add('-')">−</button>

<br>

<button onclick="add(',')">,</button>

<button onclick="add('0')">0</button>

<button onclick="add('.')">.</button>

<button class="equal" onclick="add('=')">=</button>

<br>


</body>
<script>


let display=document.getElementById("display");



function add(value){

    display.value += value;

}
</script>

</html>
